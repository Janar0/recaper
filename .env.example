# OpenRouter API key — get one at https://openrouter.ai/keys
RECAPER_OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model to use (default: anthropic/claude-sonnet-4-20250514)
# RECAPER_OPENROUTER_MODEL=anthropic/claude-sonnet-4-20250514

# Narration language (default: ru)
# RECAPER_LANGUAGE=ru

# LLM settings
# RECAPER_LLM_BATCH_SIZE=4
# RECAPER_LLM_TEMPERATURE=0.7
# RECAPER_LLM_MAX_RETRIES=3

# LLM fallback model for panel detection (defaults to ocr_model if empty)
# RECAPER_LLM_FALLBACK_MODEL=

# JPEG quality for images sent to LLM (lower = fewer tokens, saves cost)
# RECAPER_LLM_JPEG_QUALITY=80

# JPEG quality for review contact sheets
# RECAPER_CONTACT_SHEET_QUALITY=85

# TTS max retries per segment
# RECAPER_TTS_MAX_RETRIES=2

# Panel extraction
# RECAPER_MIN_PANEL_AREA_RATIO=0.02
# RECAPER_PANEL_PADDING=10
